<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="OS0-32">
  <xacro:property name="M_PI" value="3.1415926535897931" />
  <!--
    Ouster OS0-32  —  Ultra-Wide View, 32-channel
    Source: Ouster OS0 datasheet REV7 / FW3.1

    Optical:
      Vertical FOV  : 90.8° ± 1.0°  (+45.4° to -45.4°)
      Horizontal FOV: 360°
      Range (80% refl, 1024@10Hz): 75 m
      Range precision: ±0.8 cm – ±4 cm (1σ)
      noise default  : 0.008 m  (= ±0.8 cm lower-bound precision)

    IMU: InvenSense IAM-20680HT
      imu_yaw_noise_stddev          — white noise std dev (rad/s)
                                      IAM-20680HT ARW: 0.01 °/s/√Hz = 1.75e-4 rad/s/√Hz
                                      at 100 Hz → 1.75e-3 rad/s; default 0.005 is conservative.
                                      Ref: InvenSense IAM-20680HT datasheet DS-000536 rev1.0, Table 3.
      imu_yaw_bias_stddev           — Gauss-Markov dynamic bias std dev (rad/s).
                                      IAM-20680HT in-run bias instability ≈ 5 °/hr = 2.42e-5 rad/s.
      imu_yaw_bias_correlation_time — Gauss-Markov time constant (s).
                                      1000 s is conventional for MEMS gyroscopes.
  -->
  <xacro:include filename="$(find ouster_description)/urdf/os0_base.xacro"/>

  <xacro:macro name="OS0-32" params="*origin parent:=base_link name:=os0_sensor
      topic_points:=/ouster/points topic_imu:=/ouster/imu hz:=10 samples:=512
      min_range:=0.3 max_range:=75.0 noise:=0.008
      min_angle:=-${M_PI} max_angle:=${M_PI}
      lidar_link:=os0_lidar imu_link:=os0_imu
      vfov_min:=-0.79238 vfov_max:=0.79238
      imu_yaw_noise_stddev:=0.005 imu_yaw_bias_stddev:=0.0000242
      imu_yaw_bias_correlation_time:=1000.0
      base:=true cap:=halo">
    <xacro:os0_sensor sensor_model="OS0-32" parent="${parent}" name="${name}"
        topic_points="${topic_points}" topic_imu="${topic_imu}"
        hz="${hz}" samples="${samples}"
        min_range="${min_range}" max_range="${max_range}" noise="${noise}"
        min_angle="${min_angle}" max_angle="${max_angle}"
        lidar_link="${lidar_link}" imu_link="${imu_link}"
        vfov_min="${vfov_min}" vfov_max="${vfov_max}"
        imu_yaw_noise_stddev="${imu_yaw_noise_stddev}"
        imu_yaw_bias_stddev="${imu_yaw_bias_stddev}"
        imu_yaw_bias_correlation_time="${imu_yaw_bias_correlation_time}"
        base="${base}" cap="${cap}">
      <xacro:insert_block name="origin"/>
    </xacro:os0_sensor>
  </xacro:macro>
</robot>
